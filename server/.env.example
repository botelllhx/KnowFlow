# Banco de dados
DATABASE_DIALECT=postgres
PGHOST=localhost
PGUSER=knowflow
PGPORT=5432
PGDATABASE=knowflow
PGPASSWORD=your_secure_password

# Autenticação
JWT_SECRET=your_very_secure_jwt_secret_at_least_32_chars

# Servidor
PORT=3000
NODE_ENV=development

# CORS (origens separadas por vírgula)
CORS_ORIGIN=http://localhost:5173,http://localhost:3005

# Redis (opcional - graceful degradation se indisponível)
REDIS_URL=redis://localhost:6379

# Cloudinary — armazenamento de imagens e áudios
# Obter em: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
